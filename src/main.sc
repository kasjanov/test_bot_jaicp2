require: slotfilling/slotFilling.sc
  module = sys.zb-common
theme: /

    state: /hello
        intent!: /hello
        q!: *(~hello*/~привет*)*
        q!: *(~привет/~здравствуй/~hello/~hi/~добрый день/~доброе утро/~добрый вечер/~приветствую)*
        random:
            a: Привет привет
            a: И вам не хворать)
            a: Здравствуйте!
            a: Привет-привет! Я бот-помощник. Могу рассказать о погоде и курсах валют 😊
            a: И вам не хворать! Спросите меня о погоде или курсе валют.
            a: Здравствуйте! Чем могу помочь? Узнать погоду или курс валют?
            a: Доброго времени суток! Готов помочь с погодой и валютами.
    
    state: /weather
        intent!: /weather
        q!: *(~погода/~weather/~прогноз/~температура/~дождь/~снег/~холодно/~тепло/~жарко/~солнечно)*
        q!: *какая погода*
        q!: *что с погодой*
        random:
            a: Погода в городе сегодня отличная — солнечно и тепло! ☀️
            a: В городе переменная облачность, +18 °C. Возьмите зонт на всякий случай 🌤
            a: Сегодня в прохладно, возможен небольшой дождь 🌧 Не забудьте куртку!
            a: В ясная погода, идеальный день для прогулки! 😎

    state: /currency
        intent!: /currency
        q!: *(~валют/~курс/~доллар/~евро/~рубль/~currency/~exchange/~обмен/~деньги)*
        q!: *сколько стоит доллар*
        q!: *курс валют*

        random:
            a: Сегодня доллар — 90 ₽, евро — 98 ₽ 💵
            a: Актуальный курс: 1 USD ≈ 90 рублей, 1 EUR ≈ 98 рублей.
            a: Курсы валют на сегодня: доллар 90 ₽, евро 98 ₽, юань 12 ₽.
            a: По данным на сегодня: USD = 90 ₽, EUR = 98 ₽. Курс может меняться 📈
 
    state: /NoMatch
        event!: noMatch
        random:
            a: Вы можете задать вопрос по другому?
            a: Я не понял.
            a: Я не совсем понял вас. Могу рассказать о погоде ☀️ или курсе валют 💵
            a: Извините, не понял запрос. Попробуйте спросить о погоде или валютах.
            a: Хм, не уверен, что понял. Спросите меня про погоду или курс валют 😊
            a: Не распознал ваш вопрос. Уточните, пожалуйста: погода или валюта?
            a: Да уж!